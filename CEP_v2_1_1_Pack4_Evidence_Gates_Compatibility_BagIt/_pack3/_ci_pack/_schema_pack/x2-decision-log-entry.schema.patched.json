{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cep:schema:x2-decision-log-entry:v2.1.1",
  "title": "CEP X2 Decision Log Entry (v2.1.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "run_id",
    "created_at",
    "reviewer",
    "decision_type",
    "targets",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "const": "x2-decision-log-entry@v2.1.1"
    },
    "decision_id": {
      "type": "string",
      "description": "Decision identifier (UUIDv7 recommended).",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "PROMOTE_QA_TO_CANON",
        "REJECT_QA_SUGGESTION",
        "MERGE_CONSTRUCTS",
        "SPLIT_CONSTRUCT",
        "OVERRIDE_REGISTER",
        "EDIT_DEFINITION",
        "DELETE_CONSTRUCT",
        "GATE_OVERRIDE",
        "RUN_SIGNOFF"
      ],
      "description": " Added RUN_SIGNOFF for reviewer sign-off records."
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "object_type",
          "object_id"
        ],
        "properties": {
          "object_type": {
            "type": "string"
          },
          "object_id": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "before_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "after_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "rationale": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Evidence tag(s), e.g. [EVIDENCE: p.12-13]"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "approved_at"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
