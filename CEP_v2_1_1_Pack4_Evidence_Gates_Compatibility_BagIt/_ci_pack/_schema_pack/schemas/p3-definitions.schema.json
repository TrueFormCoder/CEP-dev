{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cep:schema:p3-definitions:v2.1.1",
  "title": "CEP Pass 3 — Definitions (v2.1.1)",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_id",
    "definitions",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2.1.1"
    },
    "run_id": {
      "$ref": "defs.schema.json#/$defs/uuidv7"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]{3,32}$"
    },
    "created_at": {
      "$ref": "defs.schema.json#/$defs/iso_datetime"
    },
    "definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "construct_id",
          "term",
          "register",
          "verbatim_canon",
          "interpretation"
        ],
        "properties": {
          "construct_id": {
            "type": "string",
            "pattern": "^[A-Z0-9]{6,20}$"
          },
          "term": {
            "$ref": "defs.schema.json#/$defs/term_surface"
          },
          "register": {
            "$ref": "defs.schema.json#/$defs/register"
          },
          "verbatim_canon": {
            "type": "object",
            "required": [
              "text",
              "evidence"
            ],
            "properties": {
              "text": {
                "type": "string"
              },
              "evidence": {
                "$ref": "defs.schema.json#/$defs/evidence_or_not_defined"
              }
            },
            "additionalProperties": false
          },
          "interpretation": {
            "type": "object",
            "required": [
              "text",
              "evidence"
            ],
            "properties": {
              "text": {
                "type": "string"
              },
              "evidence": {
                "$ref": "defs.schema.json#/$defs/evidence_or_not_defined"
              }
            },
            "additionalProperties": false
          },
          "fields": {
            "type": "object",
            "description": "Optional structured fields. Each string value must carry evidence tags or be Not defined in source.",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "\\[EVIDENCE:\\s*p\\.\\d+(?:-\\d+)?(?:,\\s*p\\.\\d+(?:-\\d+)?)*\\]"
                },
                {
                  "type": "string",
                  "const": "Not defined in source"
                }
              ]
            },
            "default": {}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
