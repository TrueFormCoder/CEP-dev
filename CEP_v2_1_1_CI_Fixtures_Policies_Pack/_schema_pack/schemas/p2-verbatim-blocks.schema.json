{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cep:schema:p2-verbatim-blocks:v2.1.1",
  "title": "CEP Pass 2 — Verbatim Blocks (v2.1.1)",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_id",
    "blocks",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2.1.1"
    },
    "run_id": {
      "$ref": "defs.schema.json#/$defs/uuidv7"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]{3,32}$"
    },
    "created_at": {
      "$ref": "defs.schema.json#/$defs/iso_datetime"
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "block_id",
          "construct_id",
          "page_start",
          "page_end",
          "excerpt_raw",
          "excerpt_sha256",
          "capture_method"
        ],
        "properties": {
          "block_id": {
            "type": "string",
            "pattern": "^[A-Z0-9]{6,24}$"
          },
          "construct_id": {
            "type": "string",
            "pattern": "^[A-Z0-9]{6,20}$"
          },
          "page_start": {
            "type": "integer",
            "minimum": 1
          },
          "page_end": {
            "type": "integer",
            "minimum": 1
          },
          "excerpt_raw": {
            "type": "string",
            "minLength": 1
          },
          "excerpt_sha256": {
            "$ref": "defs.schema.json#/$defs/sha256"
          },
          "capture_method": {
            "type": "string",
            "enum": [
              "substring_extract",
              "ocr_extract",
              "manual_extract"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
