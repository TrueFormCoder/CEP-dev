{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cep:schema:p1-construct-inventory:v2.1.1",
  "title": "CEP Pass 1 — Construct Inventory (v2.1.1)",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_id",
    "constructs",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2.1.1"
    },
    "run_id": {
      "$ref": "defs.schema.json#/$defs/uuidv7"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]{3,32}$"
    },
    "created_at": {
      "$ref": "defs.schema.json#/$defs/iso_datetime"
    },
    "constructs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "construct_id",
          "term",
          "term_hash_sha256",
          "type",
          "first_seen",
          "footprint_pages",
          "register"
        ],
        "properties": {
          "construct_id": {
            "type": "string",
            "pattern": "^[A-Z0-9]{6,20}$"
          },
          "term": {
            "$ref": "defs.schema.json#/$defs/term_surface"
          },
          "term_hash_sha256": {
            "$ref": "defs.schema.json#/$defs/sha256",
            "description": "Hash of exact term surface form for Hard Rule 9 enforcement"
          },
          "type": {
            "$ref": "defs.schema.json#/$defs/term_type"
          },
          "first_seen": {
            "$ref": "defs.schema.json#/$defs/page_ref"
          },
          "footprint_pages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "defs.schema.json#/$defs/page_ref"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "$ref": "defs.schema.json#/$defs/term_surface"
            },
            "default": []
          },
          "register": {
            "$ref": "defs.schema.json#/$defs/register"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
